[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=false

[internationalization]

locale/fallback="es"

[physics]

common/physics_ticks_per_second=120
3d/physics_engine="Jolt Physics"
3d/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=4
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
global_illumination/gi/use_half_resolution=true
environment/ssao/quality=3
environment/ssil/quality=3
anti_aliasing/quality/msaa_3d=2
environment/subsurface_scattering/subsurface_scattering_quality=2
global_illumination/sdfgi/probe_ray_count=0
occlusion_culling/use_occlusion_culling=true
mesh_lod/lod_change/threshold_pixels=10.0
